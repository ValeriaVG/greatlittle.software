{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
<!--for item in faq_items-->
        {
            "@type": "Question",
            "name": "{item.q}",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "{item.a}"
            }
        }
<!--/for-->
    ]
}